#!/bin/bash
# speak — reads the last Claude response aloud using Kokoro TTS (voice: af_aoede)
# Install: cp speak-cli ~/.local/bin/speak && chmod +x ~/.local/bin/speak

KOKORO="$HOME/.claude/kokoro-venv/bin/kokoro-tts"
MODEL="$HOME/.claude/kokoro-models/kokoro-v1.0.onnx"
VOICES="$HOME/.claude/kokoro-models/voices-v1.0.bin"
LAST_RESPONSE="$HOME/.claude/last_response.txt"
TMP_WAV="/tmp/claude_speak_$$.wav"
TMP_TXT="/tmp/claude_speak_$$.txt"

if [ ! -f "$LAST_RESPONSE" ] || [ ! -s "$LAST_RESPONSE" ]; then
  echo "Nothing to speak yet — chat with Claude first."
  exit 1
fi

cp "$LAST_RESPONSE" "$TMP_TXT"

"$KOKORO" "$TMP_TXT" "$TMP_WAV" \
  --voice af_aoede \
  --model "$MODEL" \
  --voices "$VOICES" 2>/dev/null && afplay "$TMP_WAV"

rm -f "$TMP_WAV" "$TMP_TXT"
